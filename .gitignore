# The workspace (parent) repo must stay lean — it only tracks context, contracts,
# and submodule pointers. Anything a service generates should never land here.
node_modules/
.env
.env.*
*.log
.DS_Store
dist/
build/
coverage/

# AI-DLC working artifacts: the aidlc-workflows methodology generates an
# aidlc-docs/ tree (requirements, architecture, construction state) at the
# workspace root during a session. Keep it untracked — it's per-session scratch,
# and committing it would bloat the repo and confuse later stages about what is
# authoritative input. (Remove this line if you decide to version those artifacts.)
aidlc-docs/
